# ============================================================
# EduAsset CMS — 环境变量配置模板
#
# 使用方法：
#   cp .env.example .env
#   然后填写下方各项配置
#
# ⚠️  .env 文件已在 .gitignore 中忽略，不会被提交到 Git
# ⚠️  请勿将真实密钥提交到代码仓库
# ============================================================

# ── 服务端口 ────────────────────────────────────────────────
# CMS 前端对外暴露的宿主机端口（默认 8080）
CMS_PORT=8080

# 上传服务内部端口（通常不需要修改）
UPLOAD_PORT=8788

# ── Overleaf 备份系统配置 ────────────────────────────────────
# Overleaf 实例地址（Docker 内访问宿主机用 host.docker.internal）
OVERLEAF_BASE_URL=http://host.docker.internal:80

# Overleaf 管理员账号
OVERLEAF_ADMIN_EMAIL=admin@example.com
OVERLEAF_ADMIN_PASSWORD=your_admin_password

# 备份文件存储路径（宿主机绝对路径）
HOST_BACKUP_PATH=/Users/your_username/overleaf-backups

# Overleaf 备份后端 API Token（由备份后端生成，用于前端鉴权）
# 访问 http://localhost:8080/cms/?token=YOUR_TOKEN 可自动写入浏览器
OVERLEAF_ACCESS_TOKEN=

# ── MinerU API 配置 ──────────────────────────────────────────
# 从 https://mineru.net 获取 API Key
# 也可在系统设置页面配置，会自动持久化到浏览器 localStorage
MINERU_API_KEY=

# ── AI 识别配置（Kimi/Moonshot）──────────────────────────────
# 从 https://platform.moonshot.cn 获取 API Key
# 也可在系统设置页面配置，会自动持久化到浏览器 localStorage
KIMI_API_KEY=

# ── 文件存储后端 ─────────────────────────────────────────────
# 可选值：minio（私有对象存储，默认）或 tmpfiles（第三方临时存储，降级用）
STORAGE_BACKEND=minio

# ── MinIO 对象存储配置 ───────────────────────────────────────
# MinIO 服务端点（Docker Compose 内部 DNS，通常无需修改）
# ⚠️ 在开发容器内直接运行（非 Docker Compose 部署）时，改为宿主机 IP（如 192.168.31.33）
MINIO_ENDPOINT=minio
# MinIO API 端口（默认 9000）
MINIO_PORT=9000
# MinIO 访问密钥（❗必须设置，请使用强密码，切勿使用默认值 minioadmin）
MINIO_ACCESS_KEY=
# MinIO 私钥（❗必须设置，请使用强密码，切勿使用默认值 minioadmin）
MINIO_SECRET_KEY=
# 存储桶名称
MINIO_BUCKET=eduassets
# 预签名 URL 有效期（秒），默认 3600（1 小时）
MINIO_PRESIGNED_EXPIRY=3600

# ── MinIO 公开访问地址（局域网/生产部署时必须配置）──────────
# upload-server 生成 presigned URL 时，将内部容器地址替换为此公开地址
# 使局域网用户浏览器可直接访问 MinIO 文件（通过 Nginx /minio/ 反向代理）
# 格式：http://<宿主机IP>:<CMS_PORT>/minio
# 示例：http://192.168.31.33:8081/minio
# 留空则不替换（本地开发模式，直接使用内部地址）
MINIO_PUBLIC_ENDPOINT=

# ── 时区 ────────────────────────────────────────────────────
TZ=Asia/Shanghai

# ── 批处理队列容量限制 ──────────────────────────────────────
# 队列中活跃任务的最大数量（pending/processing/error 状态均计入）
QUEUE_MAX_ACTIVE=10
# 单次批量提交的最大文件数
QUEUE_MAX_BATCH=10
